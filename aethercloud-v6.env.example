# Docker image built from the aethercloud branch.
AETHERCLOUD_IMAGE='ghcr.io/qqqasdwx/sing-box:aethercloud'

# Leave empty to use the interface from the IPv4 default route.
AETHERCLOUD_PARENT=''

# SOCKS5 listens only on host loopback.
AETHERCLOUD_SOCKS_PORT='11080'
AETHERCLOUD_SOCKS_USERNAME='aethercloud'
AETHERCLOUD_SOCKS_PASSWORD='replace-with-a-random-password'

# Container resource limits.
AETHERCLOUD_MEMORY='128m'
AETHERCLOUD_CPUS='1'

# Dedicated dual-stack bridge. Change these values if they overlap with an
# existing local or routed network.
AETHERCLOUD_DOCKER_NETWORK='aethercloud-v6-net'
AETHERCLOUD_IPV4_SUBNET='172.30.53.0/24'
AETHERCLOUD_IPV4_GATEWAY='172.30.53.1'
AETHERCLOUD_CONTAINER_IPV4='172.30.53.2'
AETHERCLOUD_IPV6_SUBNET='fd53:ac::/64'
AETHERCLOUD_IPV6_GATEWAY='fd53:ac::1'
AETHERCLOUD_CONTAINER_IPV6='fd53:ac::2'
