# Managed by install.sh. These host facts are detected and overwritten every
# time the installer runs. Use environment variables when an override is needed.
AETHERCLOUD_PARENT=''
DYNAMICV6_VM_UUID=''

# User settings below are preserved when the installer runs again.
# Docker image built from the aethercloud branch.
AETHERCLOUD_IMAGE='ghcr.io/qqqasdwx/aethercloud-v6:latest'

# SOCKS5 listens only on host loopback.
AETHERCLOUD_SOCKS_PORT='11080'
AETHERCLOUD_SOCKS_USERNAME='aethercloud'
AETHERCLOUD_SOCKS_PASSWORD='replace-with-a-random-password'

# Dynamic leases are exposed on container ports starting at 1080. These
# limits prevent an abnormal API response from creating unbounded processes.
AETHERCLOUD_MAX_LEASES='16'
AETHERCLOUD_MISSING_GRACE='3'

# Container resource limits.
AETHERCLOUD_MEMORY='128m'
AETHERCLOUD_CPUS='1'

# Dedicated dual-stack bridge. Change these values if they overlap with an
# existing local or routed network.
AETHERCLOUD_DOCKER_NETWORK='aethercloud-v6-net'
AETHERCLOUD_IPV4_SUBNET='172.30.53.0/24'
AETHERCLOUD_IPV4_GATEWAY='172.30.53.1'
AETHERCLOUD_CONTAINER_IPV4='172.30.53.2'

# Docker-managed IPv6 ipvlan network. The bootstrap address identifies the WAN
# interface; leased DynamicV6 addresses are added inside the container.
AETHERCLOUD_WAN_NETWORK='aethercloud-v6-wan'
AETHERCLOUD_WAN_IPV6_SUBNET='fd53:ac:ffff::/64'
AETHERCLOUD_WAN_BOOTSTRAP_IPV6='fd53:ac:ffff::2'
