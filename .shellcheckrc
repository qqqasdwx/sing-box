# ShellCheck baseline for the upstream-derived monolithic installer scripts.
# Error-level findings are fixed in source. The disabled rules below are
# legacy style, indirect invocation, and intentional glob/word-splitting idioms
# that would require broad behavioral refactors to remove safely in one pass.
disable=SC1090,SC2001,SC2004,SC2007,SC2009,SC2012,SC2015,SC2016,SC2028,SC2034,SC2038,SC2046,SC2048,SC2059,SC2076,SC2086,SC2119,SC2120,SC2128,SC2140,SC2153,SC2154,SC2155,SC2175,SC2178,SC2207,SC2231,SC2295,SC2317
