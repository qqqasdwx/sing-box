#!/usr/bin/env bash
set -Eeuo pipefail

readonly CONFIG_FILE="${AETHERCLOUD_CONFIG_FILE:-/etc/aethercloud-v6.env}"

if [ -r "$CONFIG_FILE" ]; then
  # This file is root-owned configuration and may contain the SOCKS password.
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

AETHERCLOUD_IMAGE=${AETHERCLOUD_IMAGE:-ghcr.io/qqqasdwx/sing-box:aethercloud}
AETHERCLOUD_CONTAINER=${AETHERCLOUD_CONTAINER:-aethercloud-v6}
AETHERCLOUD_PARENT=${AETHERCLOUD_PARENT:-}
AETHERCLOUD_SOCKS_PORT=${AETHERCLOUD_SOCKS_PORT:-11080}
AETHERCLOUD_SOCKS_USERNAME=${AETHERCLOUD_SOCKS_USERNAME:-aethercloud}
AETHERCLOUD_SOCKS_PASSWORD=${AETHERCLOUD_SOCKS_PASSWORD:-}
AETHERCLOUD_MEMORY=${AETHERCLOUD_MEMORY:-128m}
AETHERCLOUD_CPUS=${AETHERCLOUD_CPUS:-1}
AETHERCLOUD_DOCKER_NETWORK=${AETHERCLOUD_DOCKER_NETWORK:-aethercloud-v6-net}
AETHERCLOUD_IPV4_SUBNET=${AETHERCLOUD_IPV4_SUBNET:-172.30.53.0/24}
AETHERCLOUD_IPV4_GATEWAY=${AETHERCLOUD_IPV4_GATEWAY:-172.30.53.1}
AETHERCLOUD_CONTAINER_IPV4=${AETHERCLOUD_CONTAINER_IPV4:-172.30.53.2}
AETHERCLOUD_IPV6_SUBNET=${AETHERCLOUD_IPV6_SUBNET:-fd53:ac::/64}
AETHERCLOUD_IPV6_GATEWAY=${AETHERCLOUD_IPV6_GATEWAY:-fd53:ac::1}
AETHERCLOUD_CONTAINER_IPV6=${AETHERCLOUD_CONTAINER_IPV6:-fd53:ac::2}

usage() {
  cat <<'EOF'
Usage: aethercloud-v6 run|status|logs|test|stop|remove-network

The run command is normally managed by aethercloud-v6.service.
EOF
}

fatal() {
  printf '[aethercloud-host] ERROR: %s\n' "$*" >&2
  exit 1
}

need_command() {
  command -v "$1" >/dev/null 2>&1 || fatal "missing command: $1"
}

load_parent() {
  if [ -z "$AETHERCLOUD_PARENT" ]; then
    AETHERCLOUD_PARENT=$(ip -4 route show default 2>/dev/null | awk '{print $5; exit}')
  fi
  [ -n "$AETHERCLOUD_PARENT" ] || fatal 'unable to detect the parent interface'
  ip link show dev "$AETHERCLOUD_PARENT" >/dev/null 2>&1 ||
    fatal "parent interface does not exist: $AETHERCLOUD_PARENT"
}

router_mac() {
  local gateway mac
  gateway=$(ip -6 route show default dev "$AETHERCLOUD_PARENT" 2>/dev/null |
    awk '{for (i = 1; i <= NF; i++) if ($i == "via") {print $(i + 1); exit}}')
  [ -n "$gateway" ] || fatal "no IPv6 default gateway on $AETHERCLOUD_PARENT"

  if command -v ping >/dev/null 2>&1; then
    ping -6 -c 1 -W 2 -I "$AETHERCLOUD_PARENT" "$gateway" >/dev/null 2>&1 || true
  fi
  mac=$(ip -6 neigh show to "$gateway" dev "$AETHERCLOUD_PARENT" 2>/dev/null |
    awk '{for (i = 1; i <= NF; i++) if ($i == "lladdr") {print $(i + 1); exit}}')
  [ -n "$mac" ] || fatal "unable to resolve the router MAC for $gateway"
  printf '%s\n' "$mac"
}

container_exists() {
  docker inspect "$AETHERCLOUD_CONTAINER" >/dev/null 2>&1
}

ensure_network() {
  if docker network inspect "$AETHERCLOUD_DOCKER_NETWORK" >/dev/null 2>&1; then
    return 0
  fi

  docker network create \
    --driver bridge \
    --subnet "$AETHERCLOUD_IPV4_SUBNET" \
    --gateway "$AETHERCLOUD_IPV4_GATEWAY" \
    --ipv6 \
    --subnet "$AETHERCLOUD_IPV6_SUBNET" \
    --gateway "$AETHERCLOUD_IPV6_GATEWAY" \
    "$AETHERCLOUD_DOCKER_NETWORK" >/dev/null
}

run_service() {
  local mac vm_uuid pid link

  [ "${EUID:-$(id -u)}" -eq 0 ] || fatal 'run must be executed as root'
  [ -n "$AETHERCLOUD_SOCKS_PASSWORD" ] || fatal 'AETHERCLOUD_SOCKS_PASSWORD is required'
  need_command docker
  need_command ip
  need_command nsenter
  need_command sysctl
  load_parent
  docker info >/dev/null 2>&1 || fatal 'Docker is not available'
  ensure_network

  mac=$(router_mac)
  vm_uuid=${DYNAMICV6_VM_UUID:-}
  if [ -z "$vm_uuid" ] && [ -r /sys/class/dmi/id/product_uuid ]; then
    vm_uuid=$(tr '[:upper:]' '[:lower:]' < /sys/class/dmi/id/product_uuid | tr -d '[:space:]')
  fi
  [ -n "$vm_uuid" ] || fatal 'unable to detect the VM UUID'

  docker rm -f "$AETHERCLOUD_CONTAINER" >/dev/null 2>&1 || true

  # Invoked by the EXIT/INT/TERM trap below.
  # shellcheck disable=SC2317
  cleanup() {
    trap - EXIT INT TERM
    docker stop -t 10 "$AETHERCLOUD_CONTAINER" >/dev/null 2>&1 || true
    docker rm -f "$AETHERCLOUD_CONTAINER" >/dev/null 2>&1 || true
  }
  trap cleanup EXIT INT TERM

  docker run -d \
    --name "$AETHERCLOUD_CONTAINER" \
    --network "$AETHERCLOUD_DOCKER_NETWORK" \
    --ip "$AETHERCLOUD_CONTAINER_IPV4" \
    --ip6 "$AETHERCLOUD_CONTAINER_IPV6" \
    --cpus "$AETHERCLOUD_CPUS" \
    --memory "$AETHERCLOUD_MEMORY" \
    --pids-limit 128 \
    --cap-drop ALL \
    --cap-add NET_ADMIN \
    --cap-add SETGID \
    --cap-add SETUID \
    --cap-add CHOWN \
    --security-opt no-new-privileges:true \
    --sysctl net.ipv6.conf.all.disable_ipv6=0 \
    --sysctl net.ipv6.conf.default.disable_ipv6=0 \
    -p "127.0.0.1:${AETHERCLOUD_SOCKS_PORT}:1080/tcp" \
    -p "127.0.0.1:${AETHERCLOUD_SOCKS_PORT}:1080/udp" \
    -e "AETHERCLOUD_ROUTER_MAC=$mac" \
    -e "DYNAMICV6_VM_UUID=$vm_uuid" \
    -e "SOCKS_USERNAME=$AETHERCLOUD_SOCKS_USERNAME" \
    -e "SOCKS_PASSWORD=$AETHERCLOUD_SOCKS_PASSWORD" \
    "$AETHERCLOUD_IMAGE" >/dev/null

  pid=$(docker inspect -f '{{.State.Pid}}' "$AETHERCLOUD_CONTAINER")
  if [ -z "$pid" ] || [ "$pid" -le 0 ]; then
    fatal 'unable to read the container PID'
  fi
  link="acv6$((pid % 100000000))"

  ip link add link "$AETHERCLOUD_PARENT" name "$link" type ipvlan mode l2
  ip link set "$link" netns "$pid"
  docker exec "$AETHERCLOUD_CONTAINER" ip link set "$link" name wan0
  nsenter --target "$pid" --net sysctl -q -w net.ipv6.conf.wan0.accept_ra=0
  nsenter --target "$pid" --net sysctl -q -w net.ipv6.conf.wan0.autoconf=0
  nsenter --target "$pid" --net sysctl -q -w net.ipv6.conf.wan0.use_tempaddr=0
  docker exec "$AETHERCLOUD_CONTAINER" ip link set wan0 mtu 1280
  docker exec "$AETHERCLOUD_CONTAINER" ip link set wan0 up
  docker exec "$AETHERCLOUD_CONTAINER" touch /run/aethercloud/host-ready

  printf '[aethercloud-host] container=%s parent=%s socks=127.0.0.1:%s\n' \
    "$AETHERCLOUD_CONTAINER" "$AETHERCLOUD_PARENT" "$AETHERCLOUD_SOCKS_PORT"

  docker wait "$AETHERCLOUD_CONTAINER" >/dev/null
  exit_code=$(docker inspect -f '{{.State.ExitCode}}' "$AETHERCLOUD_CONTAINER" 2>/dev/null || printf '1')
  if [ "$exit_code" -ne 0 ]; then
    printf '[aethercloud-host] container exited with status %s\n' "$exit_code" >&2
    docker logs "$AETHERCLOUD_CONTAINER" >&2 || true
  fi
  exit "$exit_code"
}

show_status() {
  if ! container_exists; then
    printf 'container: absent\n'
    return 1
  fi
  docker inspect -f 'container: {{.State.Status}} health={{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' \
    "$AETHERCLOUD_CONTAINER"
  docker exec "$AETHERCLOUD_CONTAINER" sh -c '
    printf "lease: "; cat /run/aethercloud/ipv6_cidr 2>/dev/null || printf "pending\n"
    ip -br link show dev wan0 2>/dev/null || true
  '
}

show_logs() {
  docker logs -f "$AETHERCLOUD_CONTAINER"
}

test_proxy() {
  need_command curl
  curl -fsS \
    --proxy "socks5h://127.0.0.1:$AETHERCLOUD_SOCKS_PORT" \
    --proxy-user "$AETHERCLOUD_SOCKS_USERNAME:$AETHERCLOUD_SOCKS_PASSWORD" \
    --connect-timeout 10 \
    --max-time 30 \
    https://api64.ipify.org
  printf '\n'
}

stop_service() {
  docker stop -t 10 "$AETHERCLOUD_CONTAINER" >/dev/null 2>&1 || true
  docker rm -f "$AETHERCLOUD_CONTAINER" >/dev/null 2>&1 || true
}

remove_network() {
  docker network rm "$AETHERCLOUD_DOCKER_NETWORK" >/dev/null 2>&1 || true
}

case "${1:-}" in
  run) run_service ;;
  status) show_status ;;
  logs) show_logs ;;
  test) test_proxy ;;
  stop) stop_service ;;
  remove-network) remove_network ;;
  *) usage; exit 2 ;;
esac
